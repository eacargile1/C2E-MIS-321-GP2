# Copy to ".env" in this folder (api/) or repo root. Loaded only when ASPNETCORE_ENVIRONMENT=Development.
# Do not commit .env. Never put real secrets in THIS file — it is tracked in git.
#
# Optional: api/.env.local (gitignored) is merged AFTER api/.env — use it for OPENAI_API_KEY alone if your editor
# leaves api/.env unsaved on disk (OneDrive/Cursor). The API always reapplies the api/ folder last.

# --- Database (use one) ---
DATABASE_URL=mysql://user:password@host:3306/database
# ConnectionStrings__DefaultConnection=Server=host;Port=3306;Database=database;User ID=user;Password=password;SslMode=Preferred

# --- OpenAI (nested keys → double underscore; or OPENAI_API_KEY=...) ---
# If Windows User env has OPENAI_API_KEY or AIRecommendations__OpenAiApiKey set to empty, delete that variable so api/.env can load.
AIRecommendations__OpenAiApiKey=

# --- JWT (required at startup; min 32 chars) ---
Jwt__SigningKey=change-me-to-a-random-string-at-least-32-chars
